.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Next.js build output
.next/
out/

# Nuxt.js build output
.nuxt/
dist/

# Gatsby files
.cache/
# Comment the next line if you want to checkin your web py site
public/

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Tern JS port file
.tern-port

# Stores VS Code versions used for testing VS Code extensions
.vscode-test

